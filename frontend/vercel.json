{
  "headers": [
    {
      "source": "/index.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets|logo\\.png|sitemap\\.xml|robots\\.txt|manifest\\.webmanifest|sw\\.js|favicon\\.svg).*)",
      "destination": "/index.html"
    }
  ]
}
